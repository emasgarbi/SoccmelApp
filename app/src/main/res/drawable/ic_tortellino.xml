<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Ombra portata per dare profondità -->
    <path
        android:fillColor="#22000000"
        android:pathData="M52,82 C40,82 32,75 32,62 C32,45 42,32 52,32 C62,32 72,45 72,62 C72,75 64,82 52,82 Z" />

    <!-- Corpo principale del Tortellino con gradiente pasta all'uovo -->
    <path android:pathData="M30,60 C30,45 38,30 50,30 C62,30 70,45 70,60 C70,78 60,85 50,85 C40,85 30,78 30,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="50"
                android:centerY="55"
                android:gradientRadius="35"
                android:type="radial">
                <item android:color="#FFF176" android:offset="0.0" />
                <item android:color="#FFD54F" android:offset="0.7" />
                <item android:color="#FBC02D" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- La piega della chiusura (l'ombelico) -->
    <path
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M42,65 C45,75 55,75 58,65">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="42"
                android:startY="65"
                android:endX="58"
                android:endY="65"
                android:type="linear">
                <item android:color="#F9A825" android:offset="0.0" />
                <item android:color="#E65100" android:offset="0.5" />
                <item android:color="#F9A825" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Riflessi di luce sulla pasta -->
    <path
        android:fillColor="#44FFFFFF"
        android:pathData="M40,40 C45,35 55,35 60,40 C55,38 45,38 40,40 Z" />

    <!-- Dettagli della chiusura superiore -->
    <path
        android:fillColor="#E65100"
        android:alpha="0.3"
        android:pathData="M48,30 L52,30 L50,35 Z" />

</vector>
